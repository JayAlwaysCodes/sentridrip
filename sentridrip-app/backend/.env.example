# Zerion API Key — get yours at https://dashboard.zerion.io
ZERION_API_KEY=zk_your_api_key_here

# Agent Token — generated after creating a wallet via:
# node cli/zerion.js agent create-token --name my-bot --wallet my-wallet
ZERION_AGENT_TOKEN=ows_key_your_agent_token_here

# Solana RPC URL — use mainnet for production, devnet for testing
# Mainnet: https://api.mainnet-beta.solana.com
# Devnet:  https://api.devnet.solana.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Backend port
PORT=3001

# Environment
NODE_ENV=development
